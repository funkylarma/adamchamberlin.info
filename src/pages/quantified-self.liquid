---
title: "Quantified Self"
subhead: "A snapshot of my physical activity this week."
description: "A weekly snapshot of Adam Chamberlin's physical activity — cycling, running, walking and daily steps."
permalink: "/quantified-self/"
---

<section class="qs-section">
  <h2>Activities</h2>
  <p class="qs-note">Weekly distance in km by sport, last 12 weeks. Data refreshes with each site build.</p>

  {% if health.weeks.size > 0 %}
    <div class="qs-chart" role="img" aria-label="Stacked bar chart of weekly activity distance">
      {% for week in health.weeks %}
        <div class="qs-chart__col{% if week.isCurrent %} qs-chart__col--current{% endif %}">
          <div class="qs-chart__bar" style="height: {{ week.activityHeightPct }}%">
            {% if week.walking.distance > 0 %}
              <span class="qs-chart__seg qs-chart__seg--walking" style="flex-grow: {{ week.walking.distance }}"></span>
            {% endif %}
            {% if week.running.distance > 0 %}
              <span class="qs-chart__seg qs-chart__seg--running" style="flex-grow: {{ week.running.distance }}"></span>
            {% endif %}
            {% if week.cycling.distance > 0 %}
              <span class="qs-chart__seg qs-chart__seg--cycling" style="flex-grow: {{ week.cycling.distance }}"></span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="qs-labels">
      {% for week in health.weeks %}
        <span class="qs-label{% if week.isCurrent %} qs-label--current{% endif %}">{{ week.label }}</span>
      {% endfor %}
    </div>

    <ul class="qs-legend" aria-label="Chart legend">
      <li class="qs-legend__item">
        <span class="qs-legend__swatch qs-legend__swatch--cycling"></span> Cycling
      </li>
      <li class="qs-legend__item">
        <span class="qs-legend__swatch qs-legend__swatch--running"></span> Running
      </li>
      <li class="qs-legend__item">
        <span class="qs-legend__swatch qs-legend__swatch--walking"></span> Walking
      </li>
    </ul>
  {% else %}
    <p>No activity data available.</p>
  {% endif %}
</section>

<section class="qs-section">
  <h2>Steps</h2>
  <p class="qs-note">Total steps per week, last 12 weeks.</p>

  {% if health.weeks.size > 0 %}
    <div class="qs-chart" role="img" aria-label="Bar chart of weekly step counts">
      {% for week in health.weeks %}
        <div class="qs-chart__col{% if week.isCurrent %} qs-chart__col--current{% endif %}">
          <div class="qs-chart__bar" style="height: {{ week.stepsHeightPct }}%">
            {% if week.stepsRaw > 0 %}
              <span class="qs-chart__seg qs-chart__seg--steps"></span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="qs-labels">
      {% for week in health.weeks %}
        <span class="qs-label{% if week.isCurrent %} qs-label--current{% endif %}">{{ week.label }}</span>
      {% endfor %}
    </div>
  {% else %}
    <p>No step data available.</p>
  {% endif %}
</section>
