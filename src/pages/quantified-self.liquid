---
title: "Quantified Self"
subhead: "A snapshot of my physical activity this week."
description: "A weekly snapshot of Adam Chamberlin's physical activity — cycling, running, walking and daily steps."
permalink: "/quantified-self/"
---

<section class="qs-section">
  <h2>Steps</h2>
  <p class="qs-note">Total steps per week, last 12 weeks.</p>

  {% if health.weeks.size > 0 %}
    <div class="qs-chart" role="img" aria-label="Bar chart of weekly step counts">
      {% for week in health.weeks %}
        <div class="qs-chart__col{% if week.isCurrent %} qs-chart__col--current{% endif %}">
          <div class="qs-chart__bar" style="height: {{ week.stepsHeightPct }}%">
            {% if week.stepsRaw > 0 %}
              <span class="qs-chart__seg qs-chart__seg--steps"></span>
            {% endif %}
          </div>
          {% if week.stepsRaw > 0 %}
            <span class="qs-tooltip">{{ week.stepsFormatted }} steps</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    <div class="qs-labels qs-labels--with-values">
      {% for week in health.weeks %}
        <span class="qs-label{% if week.isCurrent %} qs-label--current{% endif %}">
          <span class="qs-label__date">{{ week.label }}</span>
          <span class="qs-label__value">{{ week.stepsFormatted }}</span>
        </span>
      {% endfor %}
    </div>
  {% else %}
    <p>No step data available.</p>
  {% endif %}
</section>

<section class="qs-section">
  <h2>Commutes</h2>
  <p class="qs-note">Bike commutes replacing car trips, last 12 weeks. CO&#x2082; saving estimated at 170&thinsp;g/km (UK average car).</p>

  {% if health.commuteTotals.rides > 0 %}
    <div class="qs-stats">
      <div class="qs-stat">
        <span class="qs-stat__value">{{ health.commuteTotals.rides }}</span>
        <span class="qs-stat__label">rides</span>
      </div>
      <div class="qs-stat">
        <span class="qs-stat__value">{{ health.commuteTotals.distanceFormatted }}</span>
        <span class="qs-stat__label">km cycled</span>
      </div>
      <div class="qs-stat qs-stat--highlight">
        <span class="qs-stat__value">{{ health.commuteTotals.co2SavedFormatted }}</span>
        <span class="qs-stat__label">kg CO&#x2082; saved</span>
      </div>
    </div>

    <div class="qs-chart" role="img" aria-label="Bar chart of weekly commute distance">
      {% for week in health.weeks %}
        <div class="qs-chart__col{% if week.isCurrent %} qs-chart__col--current{% endif %}">
          <div class="qs-chart__bar qs-chart__bar--commute" style="height: {{ week.commuteHeightPct }}%">
            {% if week.commute.count > 0 %}
              <span class="qs-chart__seg qs-chart__seg--commute"></span>
            {% endif %}
          </div>
          {% if week.commute.count > 0 %}
            <span class="qs-tooltip">{{ week.commute.distance }}&thinsp;km · {{ week.commute.duration }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    <div class="qs-labels qs-labels--with-values">
      {% for week in health.weeks %}
        <span class="qs-label{% if week.isCurrent %} qs-label--current{% endif %}">
          <span class="qs-label__date">{{ week.label }}</span>
          <span class="qs-label__value">{% if week.commute.count > 0 %}{{ week.commute.distance }}&thinsp;km{% endif %}</span>
        </span>
      {% endfor %}
    </div>
  {% else %}
    <p>No commute data available.</p>
  {% endif %}
</section>

<section class="qs-section">
  <h2>Activities</h2>
  <p class="qs-note">Weekly distance in km by sport, last 12 weeks.</p>

  {% if health.weeks.size > 0 %}
    <div class="qs-chart" role="img" aria-label="Stacked bar chart of weekly activity distance">
      {% for week in health.weeks %}
        <div class="qs-chart__col{% if week.isCurrent %} qs-chart__col--current{% endif %}">
          <div class="qs-chart__bar" style="height: {{ week.activityHeightPct }}%">
            {% if week.walking.distance > 0 %}
              <span class="qs-chart__seg qs-chart__seg--walking" style="flex-grow: {{ week.walking.distance }}"></span>
            {% endif %}
            {% if week.running.distance > 0 %}
              <span class="qs-chart__seg qs-chart__seg--running" style="flex-grow: {{ week.running.distance }}"></span>
            {% endif %}
            {% if week.cycling.distance > 0 %}
              <span class="qs-chart__seg qs-chart__seg--cycling" style="flex-grow: {{ week.cycling.distance }}"></span>
            {% endif %}
            {% if week.other.distance > 0 %}
              <span class="qs-chart__seg qs-chart__seg--other" style="flex-grow: {{ week.other.distance }}"></span>
            {% endif %}
          </div>
          {% if week.cycling.distance > 0 or week.running.distance > 0 or week.walking.distance > 0 or week.other.distance > 0 %}
            <span class="qs-tooltip">
              {% if week.cycling.distance > 0 %}<span class="qs-tooltip__line">Cycling: {{ week.cycling.distance }}&thinsp;km · {{ week.cycling.duration }}</span>{% endif %}
              {% if week.running.distance > 0 %}<span class="qs-tooltip__line">Running: {{ week.running.distance }}&thinsp;km · {{ week.running.duration }}</span>{% endif %}
              {% if week.walking.distance > 0 %}<span class="qs-tooltip__line">Walking: {{ week.walking.distance }}&thinsp;km · {{ week.walking.duration }}</span>{% endif %}
              {% if week.other.distance > 0 %}<span class="qs-tooltip__line">Other: {{ week.other.distance }}&thinsp;km · {{ week.other.duration }}</span>{% endif %}
            </span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    <div class="qs-labels">
      {% for week in health.weeks %}
        <span class="qs-label{% if week.isCurrent %} qs-label--current{% endif %}">{{ week.label }}</span>
      {% endfor %}
    </div>

    <ul class="qs-legend" aria-label="Chart legend">
      <li class="qs-legend__item">
        <span class="qs-legend__swatch qs-legend__swatch--cycling"></span> Cycling
      </li>
      <li class="qs-legend__item">
        <span class="qs-legend__swatch qs-legend__swatch--running"></span> Running
      </li>
      <li class="qs-legend__item">
        <span class="qs-legend__swatch qs-legend__swatch--walking"></span> Walking
      </li>
      <li class="qs-legend__item">
        <span class="qs-legend__swatch qs-legend__swatch--other"></span> Other
      </li>
    </ul>

    <div class="qs-table-wrap">
      <table class="qs-table">
        <thead>
          <tr>
            <th>Week</th>
            <th><span class="qs-legend__swatch qs-legend__swatch--cycling" aria-hidden="true"></span> Cycling</th>
            <th><span class="qs-legend__swatch qs-legend__swatch--running" aria-hidden="true"></span> Running</th>
            <th><span class="qs-legend__swatch qs-legend__swatch--walking" aria-hidden="true"></span> Walking</th>
            <th><span class="qs-legend__swatch qs-legend__swatch--other" aria-hidden="true"></span> Other</th>
          </tr>
        </thead>
        <tbody>
          {% assign weeks_desc = health.weeks | reverse %}
          {% for week in weeks_desc %}
            <tr{% if week.isCurrent %} class="qs-table__row--current"{% endif %}>
              <td class="qs-table__week">{{ week.label }}</td>
              <td>{% if week.cycling.count > 0 %}{{ week.cycling.duration }} &middot; {{ week.cycling.distance }}&thinsp;km{% else %}&mdash;{% endif %}</td>
              <td>{% if week.running.count > 0 %}{{ week.running.duration }} &middot; {{ week.running.distance }}&thinsp;km{% else %}&mdash;{% endif %}</td>
              <td>{% if week.walking.count > 0 %}{{ week.walking.duration }} &middot; {{ week.walking.distance }}&thinsp;km{% else %}&mdash;{% endif %}</td>
              <td>{% if week.other.count > 0 %}{{ week.other.duration }} &middot; {{ week.other.distance }}&thinsp;km{% else %}&mdash;{% endif %}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <p>No activity data available.</p>
  {% endif %}
</section>
<small>Data refreshed with every site build.</small>
